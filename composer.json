{
  "name": "seoworkerai/wordpress-connector",
  "description": "WordPress SEOWorkerAI connector plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "autoload": {
    "psr-4": {
      "SEOWorkerAI\\Connector\\": "includes/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.12",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist",
    "test:unit": "phpunit -c phpunit.xml.dist --testsuite unit",
    "test:integration": "phpunit -c phpunit.xml.dist --testsuite integration"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
